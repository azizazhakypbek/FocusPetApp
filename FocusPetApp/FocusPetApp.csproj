    <UseWPF>true</UseWPF>
    <RootNamespace>FocusPetApp</RootNamespace>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Controllers\*.cs.txt" />
